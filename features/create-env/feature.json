{
  "id": "create-env",
  "name": "Create .env",
  "category": "Developer",
  "workflow_name": "Create .env",
  "description": "Create an empty .env file.",
  "type": "automator-workflow",
  "accepts": "public.item",
  "input_mode": "as arguments",
  "script": "target=\"${1:-$PWD}\"\nif [ -f \"$target\" ]; then\n  target=\"$(dirname \"$target\")\"\nfi\n: >\"$target/.env\"\n"
}
