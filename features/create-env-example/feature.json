{
  "id": "create-env-example",
  "name": "Create .env.example",
  "category": "Developer",
  "workflow_name": "Create .env.example",
  "description": "Create an empty .env.example file.",
  "type": "automator-workflow",
  "accepts": "public.item",
  "input_mode": "as arguments",
  "script": "target=\"${1:-$PWD}\"\nif [ -f \"$target\" ]; then\n  target=\"$(dirname \"$target\")\"\nfi\n: >\"$target/.env.example\"\n"
}
