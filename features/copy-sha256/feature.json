{
  "id": "copy-sha256",
  "name": "Copy SHA256",
  "category": "Clipboard",
  "workflow_name": "Copy SHA256",
  "description": "Copy SHA256 checksums for selected files.",
  "type": "automator-workflow",
  "accepts": "public.item",
  "input_mode": "as arguments",
  "script": "shasum -a 256 \"$@\" | pbcopy\n"
}
